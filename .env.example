# =============================================================================
# nexcore-webhook-example — configuration
# Copy this file to `.env` and fill in real values. NEVER commit your `.env`.
# All values below are placeholders only.
# =============================================================================

# --- Nexcore connection (REST API; used by the `subscription` CLI) ----------
# Base URL of your Nexcore instance, no trailing slash.
NEXCORE_BASE_URL=https://api.nexcore.app
# API key created in the Nexcore GUI (see docs/generating-an-api-key.md).
# Sent as the `x-auth-apiKey` header. The tenant is derived from the key.
NEXCORE_API_KEY=<your-api-key-data>
# ID of that API key. Sent as the `x-auth-apiKeyId` header.
NEXCORE_API_KEY_ID=<your-api-key-id>

# --- Subscription self-management -------------------------------------------
# Stable identifier this app uses to find/reconcile its own subscription.
SUBSCRIPTION_EXTERNAL_ID=nexcore-webhook-example
# Comma-separated event types to subscribe to.
SUBSCRIPTION_EVENT_TYPES=export.completed
# Public HTTPS URL Nexcore will POST webhooks to (your ingress + /webhook).
PUBLIC_WEBHOOK_URL=https://<your-public-host>/webhook
# If true, register/reconcile the subscription on service startup.
AUTO_REGISTER=false

# --- Receiver & storage ------------------------------------------------------
# Directory where downloaded files are stored.
OUTPUT_DIR=./output
# Path to the local SQLite state DB (subscription state + processed event IDs).
STATE_DB_PATH=./state.sqlite
# Optional comma-separated allowlist of tenant IDs. Empty = accept all tenants.
TENANT_ALLOWLIST=

# --- Download tuning ---------------------------------------------------------
# Per-file download timeout in seconds.
DOWNLOAD_TIMEOUT_SECONDS=60
# Number of download retries on transient failures (total attempts = retries + 1).
DOWNLOAD_MAX_RETRIES=3
# Maximum size per downloaded file in bytes (0 = unlimited). Default 1 GiB.
DOWNLOAD_MAX_BYTES=1073741824

# --- Operations --------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
